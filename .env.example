GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
KIMI_API_KEY=your_kimi_api_key
KIMI_MODEL=moonshot-v1-8k
# For Neon PostgreSQL: use sslmode=require (NOT verify-full).
# Neon pooler TLS certificates do not match the pooler hostname,
# so verify-full will cause connection failures.
# Get your connection string from: https://console.neon.tech -> Connection Details
DATABASE_URL=postgres://postgres:postgres@localhost:5432/voxel_toy_box
LOCAL_DB_MODE=memory
LOCAL_PROXY_URL=http://127.0.0.1:7897
VITE_API_BASE_URL=/api/
